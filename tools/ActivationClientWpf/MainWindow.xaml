<Window x:Class="ActivationClientDemo.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="激活客户端"
        Height="640" Width="480"
        MinHeight="520" MinWidth="420"
        Background="{StaticResource PageBg}"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="激活客户端" FontSize="22" FontWeight="SemiBold" Foreground="#1A3A5C"/>
            <TextBlock Text="模拟激活流程，不进行真实服务器校验与系统激活。"
                       Foreground="{StaticResource TextSecondary}" TextWrapping="Wrap" FontSize="13" Margin="0,6,0,0"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel MaxWidth="420">
                <!-- 登录 -->
                <Border Background="{StaticResource CardBg}" BorderBrush="{StaticResource CardBorder}"
                        BorderThickness="1" CornerRadius="8" Padding="20" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="用户登录" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,12"/>
                        <TextBlock Text="用户名" FontSize="12" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,4"/>
                        <TextBox x:Name="UserNameBox" Padding="8,6" Margin="0,0,0,10"/>
                        <TextBlock Text="密码" FontSize="12" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,4"/>
                        <PasswordBox x:Name="PasswordBox" Padding="8,6" Margin="0,0,0,12"/>
                        <Button x:Name="LoginButton" Content="登录" Style="{StaticResource AccentButton}"
                                Click="LoginButton_Click" HorizontalAlignment="Stretch"/>
                        <TextBlock x:Name="LoginHint" Text="登录成功后，下方激活按钮将可用。"
                                   FontSize="12" Foreground="{StaticResource TextSecondary}" TextWrapping="Wrap" Margin="0,10,0,0"/>
                    </StackPanel>
                </Border>

                <!-- 产品激活 -->
                <Border Background="{StaticResource CardBg}" BorderBrush="{StaticResource CardBorder}"
                        BorderThickness="1" CornerRadius="8" Padding="20" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="产品激活" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="{StaticResource TextSecondary}" Margin="0,0,0,12"
                                   Text="点击按钮模拟激活流程：仅显示成功反馈，不会修改系统激活状态或联网验证。"/>
                        <Button x:Name="ActivateWindowsButton" Content="激活 Windows" IsEnabled="False"
                                Click="ActivateWindowsButton_Click" HorizontalAlignment="Stretch"/>
                        <Button x:Name="ActivateOfficeButton" Content="激活 Microsoft Office" IsEnabled="False"
                                Click="ActivateOfficeButton_Click" HorizontalAlignment="Stretch"/>
                        <Button x:Name="ActivateWpsButton" Content="激活 WPS" IsEnabled="False"
                                Click="ActivateWpsButton_Click" HorizontalAlignment="Stretch"/>
                    </StackPanel>
                </Border>

                <TextBlock x:Name="StatusText" FontSize="13" TextWrapping="Wrap" Foreground="{StaticResource TextSecondary}"/>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>

{
  "name": "zbh2",
  "private": true,
  "scripts": {
    "dev:server": "pnpm --filter server dev",
    "dev:web": "pnpm --filter web dev",
    "dev": "pnpm --parallel --filter server --filter web dev",
    "build": "pnpm --filter shared build && pnpm --filter server build && pnpm --filter web build",
    "db:generate": "pnpm --filter server db:generate",
    "db:migrate": "pnpm --filter server db:migrate",
    "db:seed": "pnpm --filter server db:seed"
  },
  "engines": {
    "node": ">=18"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["argon2", "better-sqlite3", "esbuild"]
  }
}
